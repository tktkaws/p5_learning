---
interface Props {
  sketch: string;
  width?: number;
  height?: number;
  captureFrame?: number;
}

const { sketch, width = 200, height = 200, captureFrame = 60 } = Astro.props;
---

<div
  class="p5-thumbnail"
  data-sketch={sketch}
  data-width={width}
  data-height={height}
  data-capture-frame={captureFrame}
>
  <div class="p5-thumbnail-placeholder">
    <span class="p5-thumbnail-loading"></span>
  </div>
</div>

<style>
  .p5-thumbnail {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    background: #f0f0f0;
  }

  .p5-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .p5-thumbnail canvas {
    display: none !important;
  }

  .p5-thumbnail-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .p5-thumbnail-loading {
    width: 20px;
    height: 20px;
    border: 2px solid #d1d5db;
    border-top-color: #6366f1;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  import p5 from "p5";

  document
    .querySelectorAll<HTMLDivElement>(".p5-thumbnail")
    .forEach(async (el) => {
      const name = el.dataset.sketch;
      const w = parseInt(el.dataset.width || "200");
      const h = parseInt(el.dataset.height || "200");
      const captureFrame = parseInt(el.dataset.captureFrame || "60");
      if (!name) return;

      const modules = import.meta.glob<{ default: (p: p5) => void }>(
        "../sketches/*.js",
        { eager: false }
      );

      const key = `../sketches/${name}.js`;
      const loader = modules[key];
      if (!loader) return;

      const mod = await loader();

      // 隠しコンテナ内でスケッチを実行
      const mount = document.createElement("div");
      el.appendChild(mount);

      let instance: p5 | null = null;

      const wrappedSketch = (p: p5) => {
        const original = mod.default;
        original(p);

        // setup をラップしてキャンバスサイズを上書き
        const origSetup = p.setup;
        p.setup = () => {
          p.createCanvas(w, h);
          // オリジナルの setup から createCanvas 以外を実行するため
          // 再度呼ぶと createCanvas が二重になるので、サイズだけ上書き
          origSetup?.call(p);
          p.resizeCanvas(w, h);
        };

        // draw をラップしてキャプチャ
        const origDraw = p.draw;
        p.draw = () => {
          origDraw?.call(p);

          if (p.frameCount >= captureFrame) {
            // キャンバスをキャプチャ
            const canvas = mount.querySelector("canvas");
            if (canvas) {
              const img = document.createElement("img");
              img.src = canvas.toDataURL("image/png");
              img.alt = name;

              // プレースホルダーとcanvasを除去し、imgを表示
              el.innerHTML = "";
              el.appendChild(img);
            }

            // p5 インスタンスを停止
            p.noLoop();
            instance?.remove();
          }
        };
      };

      instance = new p5(wrappedSketch, mount);
    });
</script>
