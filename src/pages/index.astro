---
import Layout from "../layouts/Layout.astro";
import P5Thumbnail from "../components/P5Thumbnail.astro";

const sketches = [
  {
    number: "01",
    title: "基本図形と色",
    desc: "circle, rect, fill, stroke — p5.js の描画の基本を学ぶ",
    href: "/sketches/01-basic-shapes",
    sketch: "basic-shapes",
    captureFrame: 5,
  },
  {
    number: "02",
    title: "アニメーション入門",
    desc: "draw() ループとフレームの仕組みで動きを作る",
    href: "/sketches/02-animation",
    sketch: "animation",
    captureFrame: 60,
  },
  {
    number: "03",
    title: "マウスインタラクション",
    desc: "mouseX / mouseY でユーザー入力に反応するスケッチ",
    href: "/sketches/03-mouse-interaction",
    sketch: "mouse-interaction",
    captureFrame: 5,
  },
  {
    number: "04",
    title: "万華鏡パターン",
    desc: "rotate / translate と対称性で万華鏡模様を自動生成",
    href: "/sketches/04-kaleidoscope",
    sketch: "kaleidoscope",
    captureFrame: 120,
  },
  {
    number: "05",
    title: "花火パーティクル",
    desc: "クラスと配列で粒子を管理し、重力で花火を表現",
    href: "/sketches/05-fireworks",
    sketch: "fireworks",
    captureFrame: 90,
  },
  {
    number: "06",
    title: "Perlinノイズフロー",
    desc: "noise() で有機的な流れを生み出すフローフィールド",
    href: "/sketches/06-noise-flow",
    sketch: "noise-flow",
    captureFrame: 150,
  },
  {
    number: "07",
    title: "キーボードお絵かき",
    desc: "keyPressed でブラシ切替、マウスで描画するペイントツール",
    href: "/sketches/07-keyboard-drawing",
    sketch: "keyboard-drawing",
    captureFrame: 5,
  },
];
---

<Layout title="Home">
  <h1 class="page-title">p5.js Learning</h1>
  <p class="page-subtitle">p5.js をひとつずつ学ぶインタラクティブノート</p>

  <ul class="sketch-grid">
    {
      sketches.map((s) => (
        <li>
          <a href={s.href}>
            <P5Thumbnail
              sketch={s.sketch}
              width={200}
              height={200}
              captureFrame={s.captureFrame}
            />
            <div class="sketch-info">
              <span class="sketch-number">#{s.number}</span>
              <div class="sketch-title">{s.title}</div>
              <div class="sketch-desc">{s.desc}</div>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</Layout>

<style>
  .sketch-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }

  .sketch-grid a {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-text);
    overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }

  .sketch-grid a:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.12);
    transform: translateY(-2px);
  }

  .sketch-info {
    padding: 0.75rem 1rem 1rem;
  }

  .sketch-number {
    font-size: 0.75rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .sketch-title {
    font-weight: 600;
    font-size: 1rem;
    margin-top: 0.15rem;
  }

  .sketch-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
    line-height: 1.5;
  }
</style>
