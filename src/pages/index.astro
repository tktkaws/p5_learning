---
import Layout from "../layouts/Layout.astro";

const sketches = [
  {
    number: "01",
    title: "基本図形と色",
    desc: "circle, rect, fill, stroke — p5.js の描画の基本を学ぶ",
    href: "/sketches/01-basic-shapes",
    thumbnail: "basic-shapes",
  },
  {
    number: "02",
    title: "アニメーション入門",
    desc: "draw() ループとフレームの仕組みで動きを作る",
    href: "/sketches/02-animation",
    thumbnail: "animation",
  },
  {
    number: "03",
    title: "マウスインタラクション",
    desc: "mouseX / mouseY でユーザー入力に反応するスケッチ",
    href: "/sketches/03-mouse-interaction",
    thumbnail: "mouse-interaction",
  },
  {
    number: "04",
    title: "万華鏡パターン",
    desc: "rotate / translate と対称性で万華鏡模様を自動生成",
    href: "/sketches/04-kaleidoscope",
    thumbnail: "kaleidoscope",
  },
  {
    number: "05",
    title: "花火パーティクル",
    desc: "クラスと配列で粒子を管理し、重力で花火を表現",
    href: "/sketches/05-fireworks",
    thumbnail: "fireworks",
  },
  {
    number: "06",
    title: "Perlinノイズフロー",
    desc: "noise() で有機的な流れを生み出すフローフィールド",
    href: "/sketches/06-noise-flow",
    thumbnail: "noise-flow",
  },
  {
    number: "07",
    title: "キーボードお絵かき",
    desc: "keyPressed でブラシ切替、マウスで描画するペイントツール",
    href: "/sketches/07-keyboard-drawing",
    thumbnail: "keyboard-drawing",
  },
  {
    number: "08",
    title: "グラデーションと色空間",
    desc: "lerpColor() と HSB モードで滑らかなグラデーションを描く",
    href: "/sketches/08-gradient-color",
    thumbnail: "gradient-color",
  },
  {
    number: "08a",
    title: "lerpColor 配色グラデーション",
    desc: "lerpColor() の 2 色を変えて、さまざまな配色のグラデーションを作る",
    href: "/sketches/08a-lerp-gradient",
    thumbnail: "lerp-gradient",
  },
  {
    number: "08b",
    title: "HSB 色相グリッド",
    desc: "彩度・明度を段階的に変えた色相グリッドで HSB を深く理解する",
    href: "/sketches/08b-hsb-grid",
    thumbnail: "hsb-grid",
  },
  {
    number: "08c",
    title: "noise グラデーション",
    desc: "noise() で色相をゆらして有機的なグラデーションアニメーション",
    href: "/sketches/08c-noise-gradient",
    thumbnail: "noise-gradient",
  },
  {
    number: "09",
    title: "座標変換の基本",
    desc: "translate / rotate / scale で時計の針を描くアニメーション",
    href: "/sketches/09-coordinate-transform",
    thumbnail: "coordinate-transform",
  },
  {
    number: "10",
    title: "テキストとフォント",
    desc: "textSize, textAlign, textFont でタイピング風アニメーション",
    href: "/sketches/10-text-font",
    thumbnail: "text-font",
  },
  {
    number: "11",
    title: "タイル模様",
    desc: "ネストした for ループで市松模様・モザイク・イスラム幾何学風パターン",
    href: "/sketches/11-tile-pattern",
    thumbnail: "tile-pattern",
  },
  {
    number: "12",
    title: "螺旋パターン",
    desc: "極座標と三角関数でアルキメデス螺旋・フィボナッチ螺旋・渦巻きを描く",
    href: "/sketches/12-spiral-pattern",
    thumbnail: "spiral-pattern",
  },
  {
    number: "13",
    title: "リサージュ曲線",
    desc: "sin / cos の周波数比を変えて描く美しい曲線。パラメータで形状が劇的に変化",
    href: "/sketches/13-lissajous-curve",
    thumbnail: "lissajous-curve",
  },
  {
    number: "14",
    title: "フラクタル樹木",
    desc: "再帰関数で枝分かれする木を描画。角度と深さで形状コントロール",
    href: "/sketches/14-fractal-tree",
    thumbnail: "fractal-tree",
  },
  {
    number: "15",
    title: "円パッキング",
    desc: "重ならないように円を敷き詰めるアルゴリズム。当たり判定と成長ロジック",
    href: "/sketches/15-circle-packing",
    thumbnail: "circle-packing",
  },
  {
    number: "16",
    title: "ペンローズタイル",
    desc: "非周期的タイル貼りを描画。黄金比に基づく美しい幾何学パターン",
    href: "/sketches/16-penrose-tile",
    thumbnail: "penrose-tile",
  },
  {
    number: "17",
    title: "群れシミュレーション（Boids）",
    desc: "分離・整列・結合の3ルールで鳥の群れのような集団行動を再現",
    href: "/sketches/17-boids",
    thumbnail: "boids",
  },
  {
    number: "18",
    title: "バネと振り子",
    desc: "フックの法則でバネを、角速度で振り子をシミュレート。物理の基礎",
    href: "/sketches/18-spring-pendulum",
    thumbnail: "spring-pendulum",
  },
];
---

<Layout title="Home">
  <h1 class="page-title">p5.js Learning</h1>
  <p class="page-subtitle">p5.js をひとつずつ学ぶインタラクティブノート</p>

  <ul class="sketch-grid">
    {
      sketches.map((s) => (
        <li>
          <a href={s.href}>
            <div class="sketch-thumbnail">
              <img
                src={`/thumbnails/${s.thumbnail}.png`}
                alt={s.title}
                loading="lazy"
              />
            </div>
            <div class="sketch-info">
              <span class="sketch-number">#{s.number}</span>
              <div class="sketch-title">{s.title}</div>
              <div class="sketch-desc">{s.desc}</div>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</Layout>

<style>
  .sketch-grid {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sketch-grid a {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-text);
    overflow: hidden;
    padding: 0.75rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .sketch-grid a:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.12);
  }

  .sketch-thumbnail {
    width: 200px;
    height: 200px;
    flex-shrink: 0;
    background: #f0f0f0;
    border-radius: 8px;
    overflow: hidden;
  }

  .sketch-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sketch-info {
    flex: 1;
    min-width: 0;
  }

  .sketch-number {
    font-size: 0.75rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .sketch-title {
    font-weight: 600;
    font-size: 1rem;
    margin-top: 0.15rem;
  }

  .sketch-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
    line-height: 1.5;
  }
</style>
