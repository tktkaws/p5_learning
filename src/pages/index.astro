---
import Layout from "../layouts/Layout.astro";

const sketches = [
  {
    number: "01",
    title: "基本図形と色",
    desc: "circle, rect, fill, stroke — p5.js の描画の基本を学ぶ",
    href: "/sketches/01-basic-shapes",
    thumbnail: "basic-shapes",
  },
  {
    number: "02",
    title: "アニメーション入門",
    desc: "draw() ループとフレームの仕組みで動きを作る",
    href: "/sketches/02-animation",
    thumbnail: "animation",
  },
  {
    number: "03",
    title: "マウスインタラクション",
    desc: "mouseX / mouseY でユーザー入力に反応するスケッチ",
    href: "/sketches/03-mouse-interaction",
    thumbnail: "mouse-interaction",
  },
  {
    number: "04",
    title: "万華鏡パターン",
    desc: "rotate / translate と対称性で万華鏡模様を自動生成",
    href: "/sketches/04-kaleidoscope",
    thumbnail: "kaleidoscope",
  },
  {
    number: "05",
    title: "花火パーティクル",
    desc: "クラスと配列で粒子を管理し、重力で花火を表現",
    href: "/sketches/05-fireworks",
    thumbnail: "fireworks",
  },
  {
    number: "06",
    title: "Perlinノイズフロー",
    desc: "noise() で有機的な流れを生み出すフローフィールド",
    href: "/sketches/06-noise-flow",
    thumbnail: "noise-flow",
  },
  {
    number: "07",
    title: "キーボードお絵かき",
    desc: "keyPressed でブラシ切替、マウスで描画するペイントツール",
    href: "/sketches/07-keyboard-drawing",
    thumbnail: "keyboard-drawing",
  },
];
---

<Layout title="Home">
  <h1 class="page-title">p5.js Learning</h1>
  <p class="page-subtitle">p5.js をひとつずつ学ぶインタラクティブノート</p>

  <ul class="sketch-grid">
    {
      sketches.map((s) => (
        <li>
          <a href={s.href}>
            <div class="sketch-thumbnail">
              <img
                src={`/thumbnails/${s.thumbnail}.png`}
                alt={s.title}
                loading="lazy"
              />
            </div>
            <div class="sketch-info">
              <span class="sketch-number">#{s.number}</span>
              <div class="sketch-title">{s.title}</div>
              <div class="sketch-desc">{s.desc}</div>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</Layout>

<style>
  .sketch-grid {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sketch-grid a {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: var(--color-text);
    overflow: hidden;
    padding: 0.75rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .sketch-grid a:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.12);
  }

  .sketch-thumbnail {
    width: 100px;
    height: 100px;
    flex-shrink: 0;
    background: #f0f0f0;
    border-radius: 8px;
    overflow: hidden;
  }

  .sketch-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sketch-info {
    flex: 1;
    min-width: 0;
  }

  .sketch-number {
    font-size: 0.75rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .sketch-title {
    font-weight: 600;
    font-size: 1rem;
    margin-top: 0.15rem;
  }

  .sketch-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
    line-height: 1.5;
  }
</style>
